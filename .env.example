# ── Walrus Memory (MemWal) ─────────────────────────────────────────────
# Create an account + delegate key in the dashboard: https://memory.walrus.xyz
# (use https://staging.memory.walrus.xyz for testnet while developing)
# Run `npm run verify:memwal` after filling these in.
MEMWAL_PRIVATE_KEY=        # 64-char Ed25519 delegate private key (hex)
MEMWAL_ACCOUNT_ID=0x...    # 0x-prefixed 32-byte Sui object id of your MemWalAccount
MEMWAL_DELEGATE_PUBLIC_KEY=   # optional: dashboard public key, lets verify catch mismatches
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz   # staging: https://relayer-staging.memory.walrus.xyz

# Public account id for the explorer link in the UI (safe to expose)
NEXT_PUBLIC_MEMWAL_ACCOUNT_ID=0x...

# ── LLM (local model over an OpenAI-compatible API, e.g. via ngrok) ─────
LOCAL_MODEL_BASE_URL=         # e.g. https://xxxx.ngrok-free.app/v1
LOCAL_MODEL_FALLBACK_URL=     # optional 2nd tunnel, tried if the primary fails
LOCAL_MODEL_NAME=             # the model id your server expects, e.g. qwen/qwen3.5-9b
LOCAL_MODEL_API_KEY=          # optional; most local servers ignore this

# ── Football data (TheSportsDB — real, free, NO key required) ──────────
# Defaults to the public test key "3"; set your own only if you have one.
THESPORTSDB_KEY=
# (advanced) FIFA World Cup = league 4429, season 2026
THESPORTSDB_LEAGUE_ID=
THESPORTSDB_SEASON=

# ── App ────────────────────────────────────────────────────────────────
# Shared secret so only trusted callers can drive the seal/resolve endpoints
EVA_BRAIN_SECRET=
